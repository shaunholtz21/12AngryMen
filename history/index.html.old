<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>League History • 12 Angry Men</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="../css/style.css" />
</head>

<body>
  <div class="page">

<header>
  <nav class="nav">
    <a href="../index.html" class="nav-title-main">Home</a>

    <div class="nav-links">
      <a href="../weekly-notes/index.html">Weekly Notes</a>
      <a href="../history/index.html">League History</a>
    </div>
  </nav>
</header>


<main>
  <div class="shell">

    <section>

      <div class="hero">
        <h1 class="hero-title">League History</h1>
        <p class="hero-sub">
          The archive of everything that made this league legendary — drafts, championships, awards, and the stories we pretend to forget.
        </p>
      </div>

      <!-- ===================== -->
      <!--   CHAMPIONSHIPS       -->
      <!-- ===================== -->
<section style="margin-top: 2rem;">
  <h2 class="section-title">Championships</h2>

  <div style="
    background: rgba(255, 255, 255, 0.03);
    padding: 1.25rem;
    border-radius: 0.9rem;
    border: 1px solid var(--border-subtle);
    margin-top: 1rem;
  ">
    <div id="championships-container" class="card-grid"></div>
  </div>
</section>

      <!-- ===================== -->
      <!--        DRAFTS         -->
      <!-- ===================== -->
<section style="margin-top: 2rem;">
  <h2 class="section-title">Drafts</h2>

  <div style="
    background: rgba(255, 255, 255, 0.03);
    padding: 1.25rem;
    border-radius: 0.9rem;
    border: 1px solid var(--border-subtle);
    margin-top: 1rem;
  ">
    <div id="drafts-container" class="card-grid"></div>
  </div>
</section>


      <!-- ===================== -->
      <!--        AWARDS         -->
      <!-- ===================== -->
<section style="margin-top:2rem;">
  <h2 class="section-title">Awards</h2>

  <article class="card card-soft">
    <div class="card-header">
      <h3 class="card-title">League Awards</h3>
      <div class="card-meta">Season Honors • Weekly Wins • Draft Night Chaos</div>
    </div>

    <div class="card-body">
      <p>
        Explore every award in league history — weekly highs, season-long dominance,
        draft‑day madness, and the annual chase for glory.
      </p>

      <a href="awards/index.html" class="card-link">View Awards →</a>
    </div>
  </article>
</section>

    </section>

  </div>
</main>

<footer class="footer">
  12 Angry Men Fantasy Football League • All objections overruled.
</footer>

</div>

<!-- =============================== -->
<!--   AUTO‑DETECT CHAMPIONSHIPS     -->
<!-- =============================== -->
<script>
async function loadChampionships() {
  const container = document.getElementById("championships-container");
  if (!container) return;

  try {
    // Load the index.json file
    const indexRes = await fetch("/12AngryMen/history/championships/index.json");
    const indexData = await indexRes.json();

    // Sort newest → oldest based on the number in the filename
    const bowls = indexData.bowls.sort((a, b) => {
      const numA = parseInt(a.match(/\d+/));
      const numB = parseInt(b.match(/\d+/));
      return numB - numA;
    });

    // Build cards
    for (const file of bowls) {
      const url = `/12AngryMen/history/championships/${file}`;

      // Fetch the file to extract its <title>
      const response = await fetch(url);
      const html = await response.text();

      const match = html.match(/<title>(.*?)<\/title>/i);
      const title = match ? match[1] : file.replace(".html", "");

      const card = document.createElement("article");
      card.className = "card card-soft";
      card.style.borderLeft = "4px solid var(--accent)";

      card.innerHTML = `
        <div class="card-header">
          <h3 class="card-title">${title}</h3>
          <div class="card-meta">Championship</div>
        </div>
        <div class="card-body">
          <p>The battle for glory in ${title}.</p>
          <a href="${url}" class="card-link">View Recap →</a>
        </div>
      `;

      container.appendChild(card);
    }

  } catch (err) {
    console.error("Error loading championships:", err);
  }
}

loadChampionships();
</script>

<!-- =============================== -->
<!--   AUTO‑DETECT DRAFTS  -->
<!-- =============================== -->

<script>
async function loadDrafts() {
  const container = document.getElementById("drafts-container");
  if (!container) return;

  try {
    // Load the index.json file
    const indexRes = await fetch("/12AngryMen/history/drafts/index.json");
    const indexData = await indexRes.json();

    // Sort newest → oldest based on the year in the filename
    const drafts = indexData.drafts.sort((a, b) => {
      const yearA = parseInt(a.match(/\d+/));
      const yearB = parseInt(b.match(/\d+/));
      return yearB - yearA;
    });

    // Build cards
    for (const file of drafts) {
      const url = `/12AngryMen/history/drafts/${file}`;

      // Fetch the file to extract its <title>
      const response = await fetch(url);
      const html = await response.text();

      const match = html.match(/<title>(.*?)<\/title>/i);
      const title = match ? match[1] : file.replace(".html", "");

      const card = document.createElement("article");
      card.className = "card card-soft";
      card.style.borderLeft = "4px solid var(--accent)";

      card.innerHTML = `
        <div class="card-header">
          <h3 class="card-title">${title}</h3>
          <div class="card-meta">Draft Recap</div>
        </div>
        <div class="card-body">
          <p>A look back at the picks, steals, reaches, and regrets of ${title}.</p>
          <a href="${url}" class="card-link">View Recap →</a>
        </div>
      `;

      container.appendChild(card);
    }

  } catch (err) {
    console.error("Error loading drafts:", err);
  }
}

loadDrafts();
</script>

</body>
</html>
